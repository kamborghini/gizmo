# ============================================================
#  Shopify MCP Server — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit your real .env file to GitHub!
# ============================================================

# ----------------------------------------------------------
# REQUIRED: Your Shopify store name
# This is the part BEFORE .myshopify.com
# Example: if your URL is my-store.myshopify.com → enter: my-store
# ----------------------------------------------------------
SHOPIFY_STORE=my-store

# ----------------------------------------------------------
# REQUIRED: Authentication
# Choose ONE of the two options below.
# ----------------------------------------------------------

# OPTION A — Recommended for most users: Static Access Token
# How to get it:
#   1. Shopify Admin → Settings → Apps and sales channels
#   2. Click "Develop apps" → Create an app
#   3. Go to Configuration → Configure Admin API scopes → select permissions → Save
#   4. Go to API credentials → Install app → Reveal token once
#   5. Copy the token below (starts with shpat_)
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTION B — Advanced: OAuth Client Credentials (enables auto token refresh)
# Only use this if you have a Shopify app with OAuth set up.
# Leave both blank if you are using Option A.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# ----------------------------------------------------------
# OPTIONAL: Shopify API version
# Default is 2024-10. Only change if you need a specific version.
# ----------------------------------------------------------
SHOPIFY_API_VERSION=2024-10

# ----------------------------------------------------------
# OPTIONAL: Server configuration
# PORT          — The port the MCP server runs on (default: 8000)
# MCP_TRANSPORT — Keep as streamable-http for use with Claude.ai
# ----------------------------------------------------------
PORT=8000
MCP_TRANSPORT=streamable-http

# ----------------------------------------------------------
# SECURITY (important): protects the /mcp endpoint, which exposes ALL Shopify
# tools including writes (delete product, cancel order, set inventory) + full
# customer data. WITHOUT this set, /mcp is LOCKED (returns 503).
# Set a long random string here, then paste the SAME value into the
# authentication-token field of your Claude.ai Shopify integration.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# ----------------------------------------------------------
MCP_BEARER_TOKEN=

# ----------------------------------------------------------
# Abuse / cost controls (sensible defaults; override only if needed).
# Rate limits are per-process, per-client (by IP) + a global AI-call ceiling.
# ----------------------------------------------------------
RATE_LIMIT_WINDOW=60        # seconds
RATE_LIMIT_PER_CLIENT=30    # requests per window per client
RATE_LIMIT_GLOBAL=150       # AI requests per window across all clients (cost ceiling)
MAX_BODY_BYTES=262144       # max request body size (256 KB)
MAX_MESSAGES=100            # max chat history length
MAX_CHAT_CHARS=100000       # max total characters in a chat request

# ============================================================
#  STORE COPILOT — the in-admin Claude chat (GET / and /api/chat)
#  Leave these blank to run only the MCP server (no chat UI).
# ============================================================

# REQUIRED for chat: your Anthropic API key (https://console.anthropic.com).
# Billed per use, separate from your Claude.ai subscription. Starts with sk-ant-.
ANTHROPIC_API_KEY=

# OPTIONAL: hybrid models. Fast model for normal chat; deep model auto-used for
# broad "analyze my store" asks and the Deep-analysis toggle.
ANTHROPIC_MODEL_FAST=claude-sonnet-4-6
ANTHROPIC_MODEL_DEEP=claude-opus-4-7

# OPTIONAL: low-stock threshold used by the Overview dashboard.
LOW_STOCK_THRESHOLD=5

# Where the saved Store Profile (brand voice, goals, strategy, toggles) is stored.
# Point this at a mounted Railway volume so it survives redeploys.
PROFILE_PATH=/data/store_profile.json

# ----------------------------------------------------------
# Embed inside Shopify admin (App Bridge) — REQUIRED. The app is embedded-only:
# every request is authenticated with a Shopify session token (no password).
# From your Shopify app: Client ID -> SHOPIFY_API_KEY (or SHOPIFY_CLIENT_ID),
# Client secret -> SHOPIFY_API_SECRET (or SHOPIFY_CLIENT_SECRET).
# ----------------------------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ============================================================
#  GOOGLE — Search Console + GA4 (optional; service-account auth)
#  Leave blank to run without Google data. When set, real search/traffic
#  metrics appear in the Overview + SEO tab and the copilot can query them.
#  Setup: create a Google Cloud service account, enable the Search Console API
#  and Google Analytics Data API, then grant the service-account EMAIL read
#  access to your GA4 property (Viewer) and your Search Console site.
# ============================================================
# The full service-account key JSON, on ONE line (or as a Railway multiline var).
GOOGLE_SERVICE_ACCOUNT_JSON=
# GA4 property id — just the number, e.g. 123456789 (Admin → Property Settings).
GA4_PROPERTY_ID=
# Search Console site — exactly as it appears in GSC:
#   URL-prefix property:  https://your-store.com/
#   Domain property:      sc-domain:your-store.com
GSC_SITE_URL=
