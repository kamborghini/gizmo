# ============================================================
#  Shopify MCP Server — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit your real .env file to GitHub!
# ============================================================

# ----------------------------------------------------------
# REQUIRED: Your Shopify store name
# This is the part BEFORE .myshopify.com
# Example: if your URL is my-store.myshopify.com → enter: my-store
# ----------------------------------------------------------
SHOPIFY_STORE=my-store

# ----------------------------------------------------------
# REQUIRED: Authentication
# Choose ONE of the two options below.
# ----------------------------------------------------------

# OPTION A — Recommended for most users: Static Access Token
# How to get it:
#   1. Shopify Admin → Settings → Apps and sales channels
#   2. Click "Develop apps" → Create an app
#   3. Go to Configuration → Configure Admin API scopes → select permissions → Save
#   4. Go to API credentials → Install app → Reveal token once
#   5. Copy the token below (starts with shpat_)
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTION B — Advanced: OAuth Client Credentials (enables auto token refresh)
# Only use this if you have a Shopify app with OAuth set up.
# Leave both blank if you are using Option A.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# ----------------------------------------------------------
# OPTIONAL: Shopify API version
# Default is 2024-10. Only change if you need a specific version.
# ----------------------------------------------------------
SHOPIFY_API_VERSION=2024-10

# ----------------------------------------------------------
# OPTIONAL: Server configuration
# PORT          — The port the MCP server runs on (default: 8000)
# MCP_TRANSPORT — Keep as streamable-http for use with Claude.ai
# ----------------------------------------------------------
PORT=8000
MCP_TRANSPORT=streamable-http

# ----------------------------------------------------------
# SECURITY (important): protects the /mcp endpoint, which exposes ALL Shopify
# tools including writes (delete product, cancel order, set inventory) + full
# customer data. WITHOUT this set, /mcp is LOCKED (returns 503).
# Set a long random string here, then paste the SAME value into the
# authentication-token field of your Claude.ai Shopify integration.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# ----------------------------------------------------------
MCP_BEARER_TOKEN=

# ============================================================
#  STORE COPILOT — the in-admin Claude chat (GET / and /api/chat)
#  Leave these blank to run only the MCP server (no chat UI).
# ============================================================

# REQUIRED for chat: your Anthropic API key (https://console.anthropic.com).
# Billed per use, separate from your Claude.ai subscription. Starts with sk-ant-.
ANTHROPIC_API_KEY=

# OPTIONAL: which Claude model the copilot uses. Sonnet is a good default;
# use claude-opus-4-7 for max quality, claude-haiku-4-5-20251001 for lowest cost.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ----------------------------------------------------------
# PHASE 1 — standalone testing (no Shopify app yet)
# Set a password to protect the chat page while you try it in a browser tab.
# ----------------------------------------------------------
DASHBOARD_PASSWORD=

# ----------------------------------------------------------
# PHASE 2 — embed inside Shopify admin (App Bridge)
# From your Shopify Partner app: Client ID -> SHOPIFY_API_KEY,
# Client secret -> SHOPIFY_API_SECRET. Setting SHOPIFY_API_KEY switches the
# page into embedded mode and verifies the admin session token on /api/chat.
# ----------------------------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
